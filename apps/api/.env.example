# Dev environment template. Copy to .env and fill in.
# .env is gitignored — never commit real secrets. (./run.sh seeds most of this
# automatically; this file documents what's needed if you set it up by hand.)

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./gink_dev.db

# ── Security (generate fresh values) ─────────────────────────────────────────
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_KEY_ENCRYPTION_KEY=

# ── Auth / admin ─────────────────────────────────────────────────────────────
# Auth is email + password (signup/login at /v1/auth/*); tokens are signed with
# JWT_SECRET above. Comma-separated emails listed here are granted admin rights +
# unmetered house AI. Register this account first so nobody else can claim it.
ADMIN_EMAILS=

# ── LLM (set at least one provider; LM Studio is the local default) ──────────
LLM_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_EMBED_MODEL=nomic-embed-text-v1.5
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Graph & Vector (optional — services degrade gracefully if unset) ─────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gink_dev_password
QDRANT_URL=http://localhost:6333

# ── Misc ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
REDIS_URL=
SENTRY_DSN=
