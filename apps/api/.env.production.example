# Production environment variables.
# Copy to .env.production and fill in all required values.
# NEVER commit .env.production to version control.
#
# ── First-deploy checklist (do these in order) ───────────────────────────────
#   1. Fill EVERY value marked CHANGE_ME below (validate_secrets aborts startup
#      on any insecure default, so a half-filled file crash-loops the api).
#   2. BILLING_PROVIDER must be `stripe` with real keys — `manual` is fatal in
#      production (it would activate any paid tier for free).
#   3. DOMAIN / GITHUB_REPO / IMAGE_TAG are consumed by docker-compose.prod.yml
#      and the Caddyfile (compose substitution + the caddy container env).
#   4. Register the ADMIN_EMAILS account first (open email+password signup), so
#      nobody else can claim the owner email on a fresh deployment.

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL is assembled by docker-compose.prod.yml from POSTGRES_* vars.
# For managed DB (RDS, Supabase), set DATABASE_URL directly:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

POSTGRES_USER=gink
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_random_password
POSTGRES_DB=gink

# ── Graph & Vector (optional) ─────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

QDRANT_URL=http://qdrant:6333

# ── Security — CRITICAL: generate fresh values for production ─────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_64

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_KEY_ENCRYPTION_KEY=CHANGE_ME_generate_with_Fernet_generate_key

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# ── Admin / owner ────────────────────────────────────────────────────────────
# Comma-separated emails granted admin + unmetered house AI. Intentionally empty
# by default (a non-empty default is an account-takeover path on fresh deploys).
ADMIN_EMAILS=

# ── Billing — CRITICAL ───────────────────────────────────────────────────────
# `manual` is FATAL in production (activates any paid tier for free).
# Choose ONE provider: `polar` (Merchant of Record — works for Saudi/no-entity
# sellers) or `stripe` (needs a Stripe-supported entity).
BILLING_PROVIDER=polar

# Polar (Merchant of Record). Webhook endpoint: <api>/v1/billing/webhook/polar
POLAR_ACCESS_TOKEN=polar_oat_CHANGE_ME
POLAR_WEBHOOK_SECRET=CHANGE_ME_standard_webhooks_secret
POLAR_SERVER=production            # or `sandbox` while testing
POLAR_PRODUCT_DEV_AI=CHANGE_ME_polar_product_id   # Plus tier
POLAR_PRODUCT_BYOK=CHANGE_ME_polar_product_id     # BYOK tier

# Stripe (only if BILLING_PROVIDER=stripe). Webhook: <api>/v1/billing/webhook/stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_DEV_AI=price_CHANGE_ME
STRIPE_PRICE_BYOK=price_CHANGE_ME

BILLING_SUCCESS_URL=https://yourapp.com/settings?billing=success
BILLING_CANCEL_URL=https://yourapp.com/pricing?billing=cancel
# Which provider the HOUSE key pays for (the free trial + dev_ai tier).
SYSTEM_LLM_PROVIDER=openai

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Deploy / infra (consumed by docker-compose.prod.yml + Caddyfile) ─────────
# DOMAIN — the public hostname Caddy serves + terminates TLS for.
DOMAIN=yourapp.com
# GITHUB_REPO — owner/repo, used to resolve the ghcr.io image names.
GITHUB_REPO=your-org/your-repo
# IMAGE_TAG — which image tag to run (CI exports the commit SHA; defaults latest).
IMAGE_TAG=latest

# ── Observability ────────────────────────────────────────────────────────────
# Get from https://sentry.io — leave blank to disable
SENTRY_DSN=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── LLM Defaults (set at least one provider) ─────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# OR use local LM Studio on host:
# LLM_PROVIDER=lmstudio
# LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
