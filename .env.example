# Copy to .env and fill in values

# === Backend ===
DATABASE_URL=postgresql+asyncpg://gink:gink_dev@localhost:5432/gink
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gink_dev_password
QDRANT_URL=http://localhost:6333

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace_me_with_a_long_random_string

# Fernet key for encrypting per-user LLM API keys at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_KEY_ENCRYPTION_KEY=replace_me_with_a_fernet_key

# === LLM default (per-user can override in Settings) ===
LLM_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_EMBED_MODEL=nomic-embed-text-v1.5

# Optional fallback global keys (only used if a user has no settings row and the default provider is one of these)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenRouter — OpenAI-compatible gateway to many models (no embeddings).
# Models are namespaced, e.g. anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-exp
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Gemini — via its OpenAI-compatible endpoint (chat + embeddings)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# === Subscriptions: house ("dev AI") model ===
# The provider the website pays for, used by the free trial + the Dev-AI tier.
# Its key is taken from the matching <PROVIDER>_API_KEY above (e.g. openai → OPENAI_API_KEY).
# BYOK subscribers never use this — only their own keys.
SYSTEM_LLM_PROVIDER=lmstudio

# === Subscriptions: plan limits (TODO real numbers) ===
# A free/Dev-AI AI call is blocked when EITHER the action OR token cap is reached.
FREE_TRIAL_MAX_ACTIONS=15
FREE_TRIAL_MAX_TOKENS=50000
DEV_AI_MAX_ACTIONS_PER_MONTH=500
DEV_AI_MAX_TOKENS_PER_MONTH=2000000

# === Billing (provider-agnostic) ===
# manual = activate instantly (dev/admin/test). stripe = Checkout + webhooks.
BILLING_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_DEV_AI=
STRIPE_PRICE_BYOK=
BILLING_SUCCESS_URL=http://localhost:3000/settings?billing=success
BILLING_CANCEL_URL=http://localhost:3000/pricing?billing=cancel

# Comma-separated emails granted admin rights (plan overrides / support tools)
# AND unlimited, never-metered AI (the site owner). Register this account first.
ADMIN_EMAILS=you@example.com

# === CORS ===
CORS_ORIGINS=http://localhost:3000

# === Frontend ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
